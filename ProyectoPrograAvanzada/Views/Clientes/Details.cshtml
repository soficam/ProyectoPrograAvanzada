@model ProyectoPrograAvanzada.Models.Cliente

@{
    ViewData["Title"] = "Detalle de cliente";
}

<style>
    .details-page-header {
        margin-bottom: 24px;
    }

        .details-page-header h2 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            color: #084c61;
        }

        .details-page-header p {
            margin: 6px 0 0 0;
            color: #6c757d;
            font-size: 14px;
        }

    .details-card {
        background-color: #f8fbfc;
        border-radius: 20px;
        padding: 28px;
        box-shadow: inset 0 0 0 1px rgba(8, 76, 97, 0.06);
        max-width: 860px;
    }

    .client-header-box {
        display: flex;
        align-items: center;
        gap: 16px;
        background-color: #ffffff;
        border: 1px solid #dbe7eb;
        border-radius: 18px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .client-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background-color: #d7e6eb;
        color: #084c61;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .client-main-info h3 {
        margin: 0;
        font-size: 24px;
        font-weight: 700;
        color: #1e293b;
    }

    .client-subtitle {
        margin-top: 6px;
        color: #64748b;
        font-size: 14px;
    }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .detail-item {
        background-color: #ffffff;
        border: 1px solid #dbe7eb;
        border-radius: 16px;
        padding: 16px;
    }

    .detail-label {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 6px;
    }

    .detail-value {
        font-size: 15px;
        font-weight: 700;
        color: #1e293b;
        word-break: break-word;
    }

    .detail-item-full {
        grid-column: 1 / -1;
    }

    .status-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .status-active {
        background-color: #d1f0dd;
        color: #18794e;
    }

    .status-inactive {
        background-color: #f8d7da;
        color: #842029;
    }

    .details-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 26px;
    }

    .btn-edit-custom {
        background-color: #084c61;
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 11px 22px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s ease;
    }

        .btn-edit-custom:hover {
            background-color: #063b4b;
            color: #fff;
            transform: translateY(-1px);
        }

    .btn-back-custom {
        background-color: #d7e6eb;
        color: #084c61;
        border: none;
        border-radius: 14px;
        padding: 11px 20px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s ease;
    }

        .btn-back-custom:hover {
            background-color: #c4dbe2;
            color: #063b4b;
        }

    @@media (max-width: 768px) {
        .details-grid {
            grid-template-columns: 1fr;
        }

        .client-header-box {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@{
    var inicial = !string.IsNullOrWhiteSpace(Model.Nombre)
        ? Model.Nombre.Trim().Substring(0, 1).ToUpper()
        : "?";
}

<div class="details-page-header">
    <h2>Detalle de cliente</h2>
    <p>Consulte la información completa del cliente seleccionado.</p>
</div>

<div class="details-card">
    <div class="client-header-box">
        <div class="client-avatar">@inicial</div>

        <div class="client-main-info">
            <h3>@Model.Nombre</h3>
            <div class="client-subtitle">ID del cliente: @Model.Id</div>
        </div>
    </div>

    <div class="details-grid">
        <div class="detail-item">
            <div class="detail-label">Cédula</div>
            <div class="detail-value">@Model.Cedula</div>
        </div>

        <div class="detail-item">
            <div class="detail-label">Estado</div>
            <div class="detail-value">
                @if (Model.Activo)
                {
                    <span class="status-badge status-active">Activo</span>
                }
                else
                {
                    <span class="status-badge status-inactive">Inactivo</span>
                }
            </div>
        </div>

        <div class="detail-item">
            <div class="detail-label">Correo electrónico</div>
            <div class="detail-value">@Model.Correo</div>
        </div>

        <div class="detail-item">
            <div class="detail-label">Teléfono</div>
            <div class="detail-value">@Model.Telefono</div>
        </div>

        <div class="detail-item detail-item-full">
            <div class="detail-label">Dirección</div>
            <div class="detail-value">@Model.Direccion</div>
        </div>
    </div>

    <div class="details-actions">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-edit-custom">
            <i class="bi bi-pencil-square"></i>
            Editar cliente
        </a>

        <a asp-action="Index" class="btn-back-custom">
            <i class="bi bi-arrow-left"></i>
            Volver al listado
        </a>
    </div>
</div>