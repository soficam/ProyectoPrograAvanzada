@model ProyectoPrograAvanzada.Models.Cliente

@{
    ViewData["Title"] = "Eliminar cliente";
}

<style>
    .delete-page-header {
        margin-bottom: 24px;
    }

        .delete-page-header h2 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            color: #084c61;
        }

        .delete-page-header p {
            margin: 6px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

    .delete-card {
        background: #f8fbfc;
        border-radius: 20px;
        padding: 28px;
        box-shadow: inset 0 0 0 1px rgba(8,76,97,0.06);
        max-width: 820px;
    }

    .warning-box {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        background: #fff4e5;
        border: 1px solid #ffd9a8;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 24px;
    }

    .warning-icon {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #ffe3bf;
        color: #b45309;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .warning-content h5 {
        margin: 0 0 6px;
        color: #9a3412;
        font-weight: 700;
    }

    .warning-content p {
        margin: 0;
        font-size: 14px;
        color: #7c2d12;
    }

    .client-preview {
        background: white;
        border: 1px solid #dbe7eb;
        border-radius: 18px;
        padding: 22px;
    }

    .client-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
    }

    .client-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #d7e6eb;
        color: #084c61;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        font-weight: 700;
    }

    .client-name {
        font-size: 22px;
        font-weight: 700;
        color: #1e293b;
    }

    .client-id {
        font-size: 13px;
        color: #64748b;
    }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2,minmax(0,1fr));
        gap: 12px;
    }

    .detail-box {
        background: #f8fbfc;
        border: 1px solid #e5eef2;
        border-radius: 12px;
        padding: 12px 14px;
    }

    .detail-label {
        font-size: 12px;
        color: #64748b;
        margin-bottom: 4px;
    }

    .detail-value {
        font-weight: 700;
        color: #1e293b;
        word-break: break-word;
    }

    .status-badge {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .status-active {
        background: #d1f0dd;
        color: #18794e;
    }

    .status-inactive {
        background: #f8d7da;
        color: #842029;
    }

    .delete-actions {
        margin-top: 24px;
        display: flex;
        gap: 12px;
    }

    .btn-delete {
        background: #dc2626;
        color: white;
        border: none;
        border-radius: 14px;
        padding: 11px 22px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-delete:hover {
            background: #b91c1c;
        }

    .btn-back {
        background: #d7e6eb;
        color: #084c61;
        border: none;
        border-radius: 14px;
        padding: 11px 20px;
        font-weight: 600;
        text-decoration: none;
    }

        .btn-back:hover {
            background: #c4dbe2;
        }
</style>

@{
    var inicial = !string.IsNullOrWhiteSpace(Model.Nombre)
        ? Model.Nombre.Trim().Substring(0, 1).ToUpper()
        : "?";
}

<div class="delete-page-header">
    <h2>Eliminar cliente</h2>
    <p>Confirme la eliminación del cliente seleccionado.</p>
</div>

<div class="delete-card">

    <div class="warning-box">
        <div class="warning-icon">
            <i class="bi bi-exclamation-triangle"></i>
        </div>

        <div class="warning-content">
            <h5>¿Está seguro de eliminar este cliente?</h5>
            <p>Esta acción eliminará permanentemente el cliente del sistema.</p>
        </div>
    </div>

    <div class="client-preview">

        <div class="client-header">
            <div class="client-avatar">@inicial</div>

            <div>
                <div class="client-name">@Model.Nombre</div>
                <div class="client-id">ID: @Model.Id</div>
            </div>
        </div>

        <div class="details-grid">

            <div class="detail-box">
                <div class="detail-label">Cédula</div>
                <div class="detail-value">@Model.Cedula</div>
            </div>

            <div class="detail-box">
                <div class="detail-label">Estado</div>
                <div class="detail-value">
                    @if (Model.Activo)
                    {
                        <span class="status-badge status-active">Activo</span>
                    }
                    else
                    {
                        <span class="status-badge status-inactive">Inactivo</span>
                    }
                </div>
            </div>

            <div class="detail-box">
                <div class="detail-label">Correo</div>
                <div class="detail-value">@Model.Correo</div>
            </div>

            <div class="detail-box">
                <div class="detail-label">Teléfono</div>
                <div class="detail-value">@Model.Telefono</div>
            </div>

            <div class="detail-box" style="grid-column:1/-1;">
                <div class="detail-label">Dirección</div>
                <div class="detail-value">@Model.Direccion</div>
            </div>

        </div>

    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="delete-actions">

            <button type="submit" class="btn-delete">
                <i class="bi bi-trash"></i>
                Eliminar cliente
            </button>

            <a asp-action="Index" class="btn-back">
                Volver al listado
            </a>

        </div>

    </form>

</div>