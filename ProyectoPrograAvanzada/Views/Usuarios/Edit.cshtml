@model ProyectoPrograAvanzada.Models.ViewModels.UsuarioFormViewModel

@{
    ViewData["Title"] = "Editar usuario";
}

<style>
    .form-page-header {
        margin-bottom: 24px;
    }

        .form-page-header h2 {
            font-size: 28px;
            font-weight: 700;
            color: #084c61;
            margin: 0;
        }

        .form-page-header p {
            margin: 6px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

    .form-card {
        background: #f8fbfc;
        border-radius: 20px;
        padding: 28px;
        max-width: 760px;
        box-shadow: inset 0 0 0 1px rgba(8, 76, 97, 0.06);
    }

    .custom-label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 6px;
    }

    .custom-input,
    .custom-select {
        border-radius: 12px;
        border: 1px solid #cfe0e6;
        padding: 11px 12px;
        min-height: 46px;
        background: white;
        transition: 0.2s ease;
    }

        .custom-input:focus,
        .custom-select:focus {
            border-color: #7fa5b1;
            box-shadow: 0 0 0 .2rem rgba(127, 165, 177, .25);
        }

    .status-box {
        margin-top: 16px;
        background: white;
        border: 1px solid #dbe7eb;
        border-radius: 14px;
        padding: 14px 16px;
    }

    .form-check-input {
        width: 2.8em;
        height: 1.4em;
        cursor: pointer;
    }

        .form-check-input:checked {
            background-color: #084c61;
            border-color: #084c61;
        }

    .form-check-label {
        font-weight: 600;
        color: #334155;
        margin-left: 8px;
        cursor: pointer;
    }

    .hint-box {
        background: #eef4f6;
        color: #64748b;
        border: 1px solid #dbe7eb;
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 13px;
        margin-top: 8px;
    }

    .form-actions {
        margin-top: 24px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-save {
        background: #084c61;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-save:hover {
            background: #063b4b;
            color: white;
        }

    .btn-back {
        background: #d7e6eb;
        color: #084c61;
        border: none;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            background: #c4dbe2;
            color: #063b4b;
        }

    .text-danger {
        font-size: 13px;
    }
</style>

<div class="form-page-header">
    <h2>Editar usuario</h2>
    <p>Actualice la información del usuario seleccionado.</p>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Nombre" class="custom-label">Nombre</label>
                <input asp-for="Nombre" class="form-control custom-input" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Correo" class="custom-label">Correo</label>
                <input asp-for="Correo" class="form-control custom-input" />
                <span asp-validation-for="Correo" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Rol" class="custom-label">Rol</label>
                <select asp-for="Rol" class="form-select custom-select">
                    <option value="">Seleccione un rol</option>
                    <option value="Sistema">Sistema</option>
                    <option value="Empleado">Empleado</option>
                </select>
                <span asp-validation-for="Rol" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Contrasena" class="custom-label">Nueva contraseña</label>
                <input asp-for="Contrasena" class="form-control custom-input" type="password" />
                <span asp-validation-for="Contrasena" class="text-danger"></span>
                <div class="hint-box">
                    Deje este campo vacío si no desea cambiar la contraseña actual.
                </div>
            </div>

            <div class="col-md-6">
                <label asp-for="ConfirmarContrasena" class="custom-label">Confirmar nueva contraseña</label>
                <input asp-for="ConfirmarContrasena" class="form-control custom-input" type="password" />
                <span asp-validation-for="ConfirmarContrasena" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="status-box">
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input" asp-for="Activo" />
                        <label class="form-check-label" asp-for="Activo">
                            Usuario activo
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save">
                <i class="bi bi-check-circle"></i>
                Guardar cambios
            </button>

            <a asp-action="Index" class="btn-back">
                <i class="bi bi-arrow-left"></i>
                Volver
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}