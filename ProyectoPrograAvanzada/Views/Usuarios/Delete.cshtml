@model ProyectoPrograAvanzada.Models.Usuario

@{
    ViewData["Title"] = "Eliminar usuario";
}

<style>

    .page-header {
        margin-bottom: 24px;
    }

        .page-header h2 {
            font-size: 28px;
            font-weight: 700;
            color: #084c61;
            margin: 0;
        }

        .page-header p {
            margin: 6px 0 0;
            color: #6c757d;
            font-size: 14px;
        }

    .delete-card {
        background: #f8fbfc;
        border-radius: 20px;
        padding: 28px;
        max-width: 800px;
        box-shadow: inset 0 0 0 1px rgba(8,76,97,0.06);
    }

    .warning-box {
        background: #fff3cd;
        border: 1px solid #ffeeba;
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 20px;
        font-weight: 600;
        color: #856404;
    }

    .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .detail-item {
        background: white;
        border: 1px solid #dbe7eb;
        border-radius: 14px;
        padding: 14px 16px;
    }

    .detail-label {
        font-size: 13px;
        color: #6b7280;
    }

    .detail-value {
        font-weight: 700;
        color: #1e293b;
    }

    .status-active {
        color: #198754;
        font-weight: 700;
    }

    .status-inactive {
        color: #dc3545;
        font-weight: 700;
    }

    .role-badge {
        background: #e7f3f7;
        color: #084c61;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
    }

    .form-actions {
        margin-top: 26px;
        display: flex;
        gap: 12px;
    }

    .btn-delete {
        background: #dc3545;
        border: none;
        border-radius: 12px;
        padding: 10px 18px;
        color: white;
        font-weight: 600;
    }

        .btn-delete:hover {
            background: #bb2d3b;
        }

    .btn-back {
        background: #d7e6eb;
        border: none;
        border-radius: 12px;
        padding: 10px 18px;
        color: #084c61;
        font-weight: 600;
        text-decoration: none;
    }

        .btn-back:hover {
            background: #c4dbe2;
        }

</style>


<div class="page-header">
    <h2>Eliminar usuario</h2>
    <p>Revise la información antes de eliminar el usuario del sistema.</p>
</div>


<div class="delete-card">

    <div class="warning-box">
        ⚠ Esta acción eliminará permanentemente el usuario.
    </div>


    <div class="details-grid">

        <div class="detail-item">
            <div class="detail-label">Nombre</div>
            <div class="detail-value">@Model.Nombre</div>
        </div>

        <div class="detail-item">
            <div class="detail-label">Correo</div>
            <div class="detail-value">@Model.Correo</div>
        </div>

        <div class="detail-item">
            <div class="detail-label">Rol</div>
            <div class="detail-value">
                <span class="role-badge">@Model.Rol</span>
            </div>
        </div>

        <div class="detail-item">
            <div class="detail-label">Estado</div>
            <div class="detail-value">
                @if (Model.Activo)
                {
                    <span class="status-active">Activo</span>
                }
                else
                {
                    <span class="status-inactive">Inactivo</span>
                }
            </div>
        </div>

    </div>


    <form asp-action="Delete">

        <input type="hidden" asp-for="Id" />

        <div class="form-actions">

            <button type="submit" class="btn-delete">
                Eliminar usuario
            </button>

            <a asp-action="Index" class="btn-back">
                Cancelar
            </a>

        </div>

    </form>

</div>