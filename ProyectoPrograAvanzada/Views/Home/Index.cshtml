@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-header {
        margin-bottom: 24px;
    }

        .dashboard-header h2 {
            margin: 0;
            font-size: 30px;
            font-weight: 700;
            color: #084c61;
        }

        .dashboard-header p {
            margin: 8px 0 0 0;
            color: #64748b;
            font-size: 14px;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 18px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: #ffffff;
        border: 1px solid #dbe7eb;
        border-radius: 20px;
        padding: 22px;
        box-shadow: 0 6px 18px rgba(8, 76, 97, 0.05);
    }

    .stat-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
    }

    .stat-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background-color: #d7e6eb;
        color: #084c61;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .stat-label {
        font-size: 14px;
        color: #64748b;
        margin-bottom: 6px;
    }

    .stat-value {
        font-size: 30px;
        font-weight: 700;
        color: #1e293b;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 18px;
    }

    .dashboard-card {
        background: #ffffff;
        border: 1px solid #dbe7eb;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 6px 18px rgba(8, 76, 97, 0.05);
    }

    .card-title {
        font-size: 18px;
        font-weight: 700;
        color: #084c61;
        margin-bottom: 16px;
    }

    .quick-links {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .quick-link {
        text-decoration: none;
        background-color: #f8fbfc;
        border: 1px solid #dbe7eb;
        border-radius: 16px;
        padding: 18px;
        display: flex;
        gap: 12px;
        align-items: center;
        transition: 0.2s ease;
    }

        .quick-link:hover {
            background-color: #eef6f8;
            transform: translateY(-1px);
        }

    .quick-link-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background-color: #d7e6eb;
        color: #084c61;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .quick-link-text strong {
        display: block;
        color: #1e293b;
        font-size: 15px;
    }

    .quick-link-text span {
        color: #64748b;
        font-size: 13px;
    }

    .info-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .info-item {
        background-color: #f8fbfc;
        border: 1px solid #e5eef2;
        border-radius: 14px;
        padding: 14px 16px;
    }

        .info-item strong {
            display: block;
            color: #1e293b;
            margin-bottom: 4px;
        }

        .info-item span {
            color: #64748b;
            font-size: 13px;
        }

    @@media (max-width: 1100px) {
        .stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 700px) {
        .stats-grid,
        .quick-links {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dashboard-header">
    <h2>Dashboard</h2>
    <p>Bienvenido al sistema de inventario y pedidos B2B. Desde aquí puede consultar y gestionar los módulos principales.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon">
                <i class="bi bi-receipt"></i>
            </div>
        </div>
        <div class="stat-label">Pedidos</div>
        <div class="stat-value">@ViewBag.TotalPedidos</div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon">
                <i class="bi bi-box-seam"></i>
            </div>
        </div>
        <div class="stat-label">Productos</div>
        <div class="stat-value">@ViewBag.TotalProductos</div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon">
                <i class="bi bi-people"></i>
            </div>
        </div>
        <div class="stat-label">Clientes</div>
        <div class="stat-value">@ViewBag.TotalClientes</div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon">
                <i class="bi bi-person-gear"></i>
            </div>
        </div>
        <div class="stat-label">Usuarios</div>
        <div class="stat-value">@ViewBag.TotalUsuarios</div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="dashboard-card">
        <div class="card-title">Accesos rápidos</div>

        <div class="quick-links">
            <a asp-controller="Pedidoes" asp-action="Create" class="quick-link">
                <div class="quick-link-icon">
                    <i class="bi bi-plus-circle"></i>
                </div>
                <div class="quick-link-text">
                    <strong>Nuevo pedido</strong>
                    <span>Registrar una nueva orden</span>
                </div>
            </a>

            <a asp-controller="Productoes" asp-action="Index" class="quick-link">
                <div class="quick-link-icon">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div class="quick-link-text">
                    <strong>Productos</strong>
                    <span>Consultar catálogo</span>
                </div>
            </a>

            <a asp-controller="Clientes" asp-action="Index" class="quick-link">
                <div class="quick-link-icon">
                    <i class="bi bi-people"></i>
                </div>
                <div class="quick-link-text">
                    <strong>Clientes</strong>
                    <span>Gestionar clientes</span>
                </div>
            </a>

            <a asp-controller="Usuarios" asp-action="Index" class="quick-link">
                <div class="quick-link-icon">
                    <i class="bi bi-person-gear"></i>
                </div>
                <div class="quick-link-text">
                    <strong>Usuarios</strong>
                    <span>Administrar accesos</span>
                </div>
            </a>
        </div>
    </div>

    <div class="dashboard-card">
        <div class="card-title">Resumen del sistema</div>

        <div class="info-list">
            <div class="info-item">
                <strong>Módulo principal</strong>
                <span>Pedidos centraliza la gestión de la orden y sus productos.</span>
            </div>

            <div class="info-item">
                <strong>Inventario</strong>
                <span>Los productos incluyen categoría, precio, impuesto y stock.</span>
            </div>

            <div class="info-item">
                <strong>Clientes y usuarios</strong>
                <span>Puede administrar clientes y usuarios desde sus respectivos módulos.</span>
            </div>

            <div class="info-item">
                <strong>Estado actual</strong>
                <span>La interfaz ha sido adaptada a un flujo más intuitivo y visual.</span>
            </div>
        </div>
    </div>
</div>