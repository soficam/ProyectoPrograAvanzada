@model ProyectoPrograAvanzada.Models.Producto

@{
    ViewData["Title"] = "Nuevo producto";
}

<style>
    .form-page-header {
        margin-bottom: 24px;
    }

        .form-page-header h2 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            color: #084c61;
        }

        .form-page-header p {
            margin: 6px 0 0 0;
            color: #6c757d;
            font-size: 14px;
        }

    .form-card {
        background-color: #f8fbfc;
        border-radius: 20px;
        padding: 28px;
        box-shadow: inset 0 0 0 1px rgba(8, 76, 97, 0.06);
        max-width: 950px;
    }

    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #084c61;
        margin-bottom: 20px;
    }

    .custom-label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 8px;
    }

    .custom-input,
    .custom-select {
        border-radius: 14px;
        border: 1px solid #cfe0e6;
        padding: 12px 14px;
        min-height: 48px;
        box-shadow: none;
        transition: 0.2s ease;
        background-color: #fff;
    }

        .custom-input:focus,
        .custom-select:focus {
            border-color: #7fa5b1;
            box-shadow: 0 0 0 0.2rem rgba(127, 165, 177, 0.25);
        }

    .form-hint {
        margin-top: 8px;
        font-size: 13px;
        color: #6b7280;
    }

    .status-box {
        margin-top: 10px;
        background-color: #ffffff;
        border: 1px solid #dbe7eb;
        border-radius: 16px;
        padding: 16px 18px;
    }

    .status-box-title {
        font-weight: 700;
        color: #084c61;
        margin-bottom: 6px;
    }

    .status-box-text {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 12px;
    }

    .form-check-input {
        width: 2.8em;
        height: 1.4em;
        cursor: pointer;
    }

        .form-check-input:checked {
            background-color: #084c61;
            border-color: #084c61;
        }

    .form-check-label {
        font-weight: 600;
        color: #334155;
        margin-left: 8px;
        cursor: pointer;
    }

    .preview-card {
        background-color: #ffffff;
        border: 1px dashed #cbd5e1;
        border-radius: 18px;
        padding: 20px;
        height: 100%;
    }

    .preview-title {
        font-size: 16px;
        font-weight: 700;
        color: #084c61;
        margin-bottom: 16px;
    }

    .preview-image-box {
        width: 100%;
        height: 220px;
        border-radius: 16px;
        background-color: #eef4f6;
        border: 1px solid #dbe7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        margin-bottom: 14px;
    }

        .preview-image-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

    .preview-placeholder {
        color: #7fa5b1;
        text-align: center;
    }

        .preview-placeholder i {
            font-size: 38px;
            display: block;
            margin-bottom: 8px;
        }

    .preview-name {
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 6px;
    }

    .preview-meta {
        font-size: 14px;
        color: #64748b;
        margin-bottom: 6px;
    }

    .preview-price {
        font-size: 20px;
        font-weight: 700;
        color: #084c61;
        margin-top: 10px;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 28px;
    }

    .btn-save-custom {
        background-color: #084c61;
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 11px 22px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s ease;
    }

        .btn-save-custom:hover {
            background-color: #063b4b;
            color: #fff;
            transform: translateY(-1px);
        }

    .btn-back-custom {
        background-color: #d7e6eb;
        color: #084c61;
        border: none;
        border-radius: 14px;
        padding: 11px 20px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s ease;
    }

        .btn-back-custom:hover {
            background-color: #c4dbe2;
            color: #063b4b;
        }

    .validation-summary-errors ul {
        margin-bottom: 16px;
        padding-left: 18px;
    }

    .text-danger {
        font-size: 13px;
    }
</style>

<div class="form-page-header">
    <h2>Nuevo producto</h2>
    <p>Complete la información para registrar un nuevo producto en el sistema.</p>
</div>

<div class="form-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="section-title">Información general</div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label custom-label">Nombre del producto</label>
                        <input asp-for="Nombre" class="form-control custom-input"  id="Nombre" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoriaId" class="form-label custom-label">Categoría</label>
                        <select asp-for="CategoriaId" class="form-select custom-select" asp-items="ViewBag.CategoriaId" id="CategoriaId">
                            <option value="">Seleccione una categoría</option>
                        </select>
                        <span asp-validation-for="CategoriaId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Precio" class="form-label custom-label">Precio</label>
                        <input asp-for="Precio" class="form-control custom-input" placeholder="0.00" id="Precio" />
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ImpuestoPorc" class="form-label custom-label">Impuesto (%)</label>
                        <input asp-for="ImpuestoPorc" class="form-control custom-input" id="ImpuestoPorc" />
                        <span asp-validation-for="ImpuestoPorc" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Stock" class="form-label custom-label">Stock</label>
                        <input asp-for="Stock" class="form-control custom-input" placeholder="0" id="Stock" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="ImagenUrl" class="form-label custom-label">URL de imagen del producto</label>
                        <input asp-for="ImagenUrl" class="form-control custom-input" placeholder="https://..." id="ImagenUrl" />
                        <span asp-validation-for="ImagenUrl" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <div class="status-box">
                            <div class="status-box-title">Estado del producto</div>
                            <div class="status-box-text">
                                Indique si el producto estará disponible dentro del sistema.
                            </div>

                            <div class="form-check form-switch">
                                <input class="form-check-input" asp-for="Activo" id="Activo" />
                                <label class="form-check-label" asp-for="Activo">
                                    Producto activo
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="preview-card">
                    <div class="preview-title">Vista previa</div>

                    <div class="preview-image-box">
                        <img id="previewImage" alt="Vista previa del producto" />
                        <div class="preview-placeholder" id="previewPlaceholder">
                            <i class="bi bi-image"></i>
                            Sin imagen
                        </div>
                    </div>

                    <div class="preview-name" id="previewNombre">Nombre del producto</div>
                    <div class="preview-meta" id="previewCategoria">Categoría: Sin seleccionar</div>
                    <div class="preview-meta" id="previewStock">Stock: 0 unidades</div>
                    <div class="preview-meta" id="previewEstado">Estado: Inactivo</div>
                    <div class="preview-price" id="previewPrecio">₡ 0.00</div>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save-custom">
                <i class="bi bi-check-circle"></i>
                Guardar producto
            </button>

            <a asp-action="Index" class="btn-back-custom">
                <i class="bi bi-arrow-left"></i>
                Volver al listado
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const nombreInput = document.getElementById('Nombre');
        const categoriaSelect = document.getElementById('CategoriaId');
        const precioInput = document.getElementById('Precio');
        const stockInput = document.getElementById('Stock');
        const imagenInput = document.getElementById('ImagenUrl');
        const activoInput = document.getElementById('Activo');

        const previewNombre = document.getElementById('previewNombre');
        const previewCategoria = document.getElementById('previewCategoria');
        const previewPrecio = document.getElementById('previewPrecio');
        const previewStock = document.getElementById('previewStock');
        const previewEstado = document.getElementById('previewEstado');
        const previewImage = document.getElementById('previewImage');
        const previewPlaceholder = document.getElementById('previewPlaceholder');

        function actualizarPreview() {
            previewNombre.textContent = nombreInput.value.trim() || 'Nombre del producto';

            const categoriaTexto = categoriaSelect.options[categoriaSelect.selectedIndex]?.text || 'Sin seleccionar';
            previewCategoria.textContent = 'Categoría: ' + (categoriaSelect.value ? categoriaTexto : 'Sin seleccionar');

            const precio = precioInput.value.trim() || '0.00';
            previewPrecio.textContent = '₡ ' + precio;

            const stock = stockInput.value.trim() || '0';
            previewStock.textContent = 'Stock: ' + stock + ' unidades';

            previewEstado.textContent = 'Estado: ' + (activoInput.checked ? 'Activo' : 'Inactivo');

            const url = imagenInput.value.trim();
            if (url !== '') {
                previewImage.src = url;
                previewImage.style.display = 'block';
                previewPlaceholder.style.display = 'none';

                previewImage.onerror = function () {
                    previewImage.style.display = 'none';
                    previewPlaceholder.style.display = 'block';
                };
            } else {
                previewImage.style.display = 'none';
                previewPlaceholder.style.display = 'block';
            }
        }

        nombreInput.addEventListener('input', actualizarPreview);
        categoriaSelect.addEventListener('change', actualizarPreview);
        precioInput.addEventListener('input', actualizarPreview);
        stockInput.addEventListener('input', actualizarPreview);
        imagenInput.addEventListener('input', actualizarPreview);
        activoInput.addEventListener('change', actualizarPreview);

        actualizarPreview();
    </script>
}