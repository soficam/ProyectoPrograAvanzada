@model ProyectoPrograAvanzada.Models.Producto

@{
    ViewData["Title"] = "Eliminar producto";
}

<style>
    .delete-page-header {
        margin-bottom: 24px;
    }

        .delete-page-header h2 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            color: #084c61;
        }

        .delete-page-header p {
            margin: 6px 0 0 0;
            color: #6c757d;
            font-size: 14px;
        }

    .delete-card {
        background-color: #f8fbfc;
        border-radius: 20px;
        padding: 28px;
        box-shadow: inset 0 0 0 1px rgba(8, 76, 97, 0.06);
    }

    .warning-box {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        background-color: #fff4e5;
        border: 1px solid #ffd9a8;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 24px;
    }

    .warning-icon {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background-color: #ffe3bf;
        color: #b45309;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .warning-content h5 {
        margin: 0 0 6px 0;
        color: #9a3412;
        font-weight: 700;
    }

    .warning-content p {
        margin: 0;
        font-size: 14px;
        color: #7c2d12;
    }

    .product-preview {
        background-color: white;
        border: 1px solid #dbe7eb;
        border-radius: 18px;
        padding: 20px;
    }

    .product-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 24px;
        align-items: center;
    }

    .product-image {
        width: 100%;
        height: 240px;
        border-radius: 16px;
        background-color: #eef4f6;
        border: 1px solid #dbe7eb;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .product-placeholder {
        color: #7fa5b1;
        text-align: center;
    }

        .product-placeholder i {
            font-size: 36px;
            display: block;
            margin-bottom: 6px;
        }

    .product-name {
        font-size: 22px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 10px;
    }

    .price {
        font-size: 24px;
        font-weight: 700;
        color: #084c61;
        margin-bottom: 12px;
    }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0,1fr));
        gap: 12px;
    }

    .detail-box {
        background-color: #f8fbfc;
        border: 1px solid #e5eef2;
        border-radius: 12px;
        padding: 10px 12px;
    }

    .detail-label {
        font-size: 12px;
        color: #64748b;
    }

    .detail-value {
        font-weight: 700;
        color: #1e293b;
    }

    .status-badge,
    .category-badge,
    .stock-badge {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .status-active {
        background-color: #d1f0dd;
        color: #18794e;
    }

    .status-inactive {
        background-color: #f8d7da;
        color: #842029;
    }

    .category-badge {
        background-color: #e0f2fe;
        color: #0369a1;
    }

    .stock-low {
        background-color: #fff3cd;
        color: #946200;
    }

    .stock-ok {
        background-color: #dbeafe;
        color: #1d4ed8;
    }

    .delete-actions {
        margin-top: 24px;
        display: flex;
        gap: 12px;
    }

    .btn-delete-custom {
        background-color: #dc2626;
        color: white;
        border: none;
        border-radius: 14px;
        padding: 11px 22px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-delete-custom:hover {
            background-color: #b91c1c;
        }

    .btn-back-custom {
        background-color: #d7e6eb;
        color: #084c61;
        border: none;
        border-radius: 14px;
        padding: 11px 20px;
        font-weight: 600;
        text-decoration: none;
    }

        .btn-back-custom:hover {
            background-color: #c4dbe2;
        }
</style>

<div class="delete-page-header">
    <h2>Eliminar producto</h2>
    <p>Confirme la eliminación del producto seleccionado.</p>
</div>

<div class="delete-card">

    <div class="warning-box">
        <div class="warning-icon">
            <i class="bi bi-exclamation-triangle"></i>
        </div>

        <div class="warning-content">
            <h5>¿Está seguro de eliminar este producto?</h5>
            <p>
                Esta acción eliminará permanentemente el producto del sistema.
            </p>
        </div>
    </div>

    <div class="product-preview">
        <div class="product-layout">

            <div class="product-image">
                @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" alt="@Model.Nombre" />
                }
                else
                {
                    <div class="product-placeholder">
                        <i class="bi bi-image"></i>
                        Sin imagen
                    </div>
                }
            </div>

            <div>

                <div class="product-name">@Model.Nombre</div>

                <div class="price">₡ @Model.Precio</div>

                <div class="details-grid">

                    <div class="detail-box">
                        <div class="detail-label">Categoría</div>
                        <div class="detail-value">
                            <span class="category-badge">
                                @(Model.Categoria != null ? Model.Categoria.Nombre : "Sin categoría")
                            </span>
                        </div>
                    </div>

                    <div class="detail-box">
                        <div class="detail-label">Estado</div>
                        <div class="detail-value">
                            @if (Model.Activo)
                            {
                                <span class="status-badge status-active">Activo</span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">Inactivo</span>
                            }
                        </div>
                    </div>

                    <div class="detail-box">
                        <div class="detail-label">Impuesto</div>
                        <div class="detail-value">@Model.ImpuestoPorc %</div>
                    </div>

                    <div class="detail-box">
                        <div class="detail-label">Stock</div>
                        <div class="detail-value">
                            @if (Model.Stock <= 5)
                            {
                                <span class="stock-badge stock-low">@Model.Stock unidades</span>
                            }
                            else
                            {
                                <span class="stock-badge stock-ok">@Model.Stock unidades</span>
                            }
                        </div>
                    </div>

                </div>

            </div>

        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="delete-actions">
            <button type="submit" class="btn-delete-custom">
                <i class="bi bi-trash"></i>
                Eliminar producto
            </button>

            <a asp-action="Index" class="btn-back-custom">
                Volver al listado
            </a>
        </div>
    </form>

</div>