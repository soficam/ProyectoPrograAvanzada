@model IEnumerable<ProyectoPrograAvanzada.Models.Pedido>

<div class="container mt-4">
    <h3>📦 Mis pedidos</h3>
    <table class="table table-striped table-hover mt-3">
        <thead class="table-light">
            <tr>
                <th># Pedido</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Total</th>
                <th>Detalles</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model)
            {
                <tr>
                    <td>@pedido.Id</td>
                    <td>@pedido.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@pedido.Estado</td>
                    <td>@pedido.Total.ToString("C")</td>
                    <td>
                        <a href="@Url.Action("Confirmacion", "Pago", new { id = pedido.Id })"
                           class="btn btn-sm btn-outline-primary">
                            Ver
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
