@model IEnumerable<ProyectoPrograAvanzada.Models.Categorium>

@{
    ViewData["Title"] = "Categorías";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 24px;
    }

    .page-title h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #084c61;
    }

    .page-title p {
        margin: 6px 0 0 0;
        color: #6c757d;
        font-size: 14px;
    }

    .btn-add {
        background-color: #084c61;
        color: white;
        border: none;
        border-radius: 14px;
        padding: 10px 18px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s ease;
    }

        .btn-add:hover {
            background-color: #063b4b;
            color: white;
            transform: translateY(-1px);
        }

    .table-card {
        background-color: #f8fbfc;
        border-radius: 18px;
        padding: 20px;
        box-shadow: inset 0 0 0 1px rgba(8, 76, 97, 0.06);
    }

    .custom-table {
        margin: 0;
        vertical-align: middle;
    }

        .custom-table thead th {
            background-color: #d7e6eb;
            color: #084c61;
            font-weight: 700;
            border: none;
            padding: 14px;
            font-size: 14px;
        }

            .custom-table thead th:first-child {
                border-top-left-radius: 14px;
                border-bottom-left-radius: 14px;
            }

            .custom-table thead th:last-child {
                border-top-right-radius: 14px;
                border-bottom-right-radius: 14px;
            }

        .custom-table tbody tr {
            background-color: white;
            transition: 0.2s ease;
        }

            .custom-table tbody tr:hover {
                background-color: #f1f7f9;
            }

        .custom-table td {
            padding: 16px 14px;
            border-top: 10px solid transparent;
            color: #334155;
        }

    .status-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .status-active {
        background-color: #d1f0dd;
        color: #18794e;
    }

    .status-inactive {
        background-color: #f8d7da;
        color: #842029;
    }

    .actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: 0.2s ease;
        font-size: 15px;
    }

    .btn-edit {
        background-color: #dbeafe;
        color: #1d4ed8;
    }

        .btn-edit:hover {
            background-color: #bfdbfe;
            color: #1d4ed8;
        }

    .btn-details {
        background-color: #e0f2fe;
        color: #0369a1;
    }

        .btn-details:hover {
            background-color: #bae6fd;
            color: #0369a1;
        }

    .btn-delete {
        background-color: #fee2e2;
        color: #dc2626;
    }

        .btn-delete:hover {
            background-color: #fecaca;
            color: #dc2626;
        }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: #6b7280;
    }

        .empty-state i {
            font-size: 42px;
            color: #7fa5b1;
            margin-bottom: 12px;
            display: block;
        }
        .filter-control {
    height: 44px;
    border: 1px solid #cfe0e6;
    border-radius: 12px;
    padding: 0 12px;
    font-size: 14px;
}
</style>

<div class="page-header">
    <div class="page-title">
        <h2>Categorías</h2>
        <p>Gestione las categorías disponibles dentro del sistema.</p>
    </div>
    <form method="get" style="display:flex; gap:10px;">
        <input type="text" name="busqueda" value="@ViewBag.Busqueda"
               class="filter-control"
               placeholder="Buscar categoría..." />

        <button type="submit" class="btn-add">
            <i class="bi bi-search"></i>
        </button>

        <a asp-action="Index" class="btn-add" style="background:#d7e6eb; color:#084c61;">
            <i class="bi bi-x-circle"></i>
        </a>
    </form>

    <a asp-action="Create" class="btn-add">
        <i class="bi bi-plus-circle"></i>
        Nueva categoría
    </a>
</div>

<div class="table-card">
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table custom-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Estado</th>
                        <th style="width: 160px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td>
                                @if (item.Activo == true)
                                {
                                    <span class="status-badge status-active">Activa</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Inactiva</span>
                                }
                            </td>
                            <td>
                                <div class="actions">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details" title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-grid"></i>
            <h5>No hay categorías registradas</h5>
            <p>Cuando agregue una nueva categoría, aparecerá listada aquí.</p>
        </div>
    }
</div>