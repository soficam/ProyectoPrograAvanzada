@model ProyectoPrograAvanzada.Models.Categorium

@{
    ViewData["Title"] = "Editar categoría";
}

<style>
    .form-page-header {
        margin-bottom: 24px;
    }

        .form-page-header h2 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            color: #084c61;
        }

        .form-page-header p {
            margin: 6px 0 0 0;
            color: #6c757d;
            font-size: 14px;
        }

    .form-card {
        background-color: #f8fbfc;
        border-radius: 20px;
        padding: 28px;
        box-shadow: inset 0 0 0 1px rgba(8, 76, 97, 0.06);
        max-width: 720px;
    }

    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #084c61;
        margin-bottom: 20px;
    }

    .custom-label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 8px;
    }

    .custom-input {
        border-radius: 14px;
        border: 1px solid #cfe0e6;
        padding: 12px 14px;
        min-height: 48px;
        box-shadow: none;
        transition: 0.2s ease;
    }

        .custom-input:focus {
            border-color: #7fa5b1;
            box-shadow: 0 0 0 0.2rem rgba(127, 165, 177, 0.25);
        }

    .form-hint {
        margin-top: 8px;
        font-size: 13px;
        color: #6b7280;
    }

    .status-box {
        margin-top: 18px;
        background-color: #ffffff;
        border: 1px solid #dbe7eb;
        border-radius: 16px;
        padding: 16px 18px;
    }

    .status-box-title {
        font-weight: 700;
        color: #084c61;
        margin-bottom: 6px;
    }

    .status-box-text {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 12px;
    }

    .form-check-input {
        width: 2.8em;
        height: 1.4em;
        cursor: pointer;
    }

        .form-check-input:checked {
            background-color: #084c61;
            border-color: #084c61;
        }

    .form-check-label {
        font-weight: 600;
        color: #334155;
        margin-left: 8px;
        cursor: pointer;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 26px;
    }

    .btn-save-custom {
        background-color: #084c61;
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 11px 22px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s ease;
    }

        .btn-save-custom:hover {
            background-color: #063b4b;
            color: #fff;
            transform: translateY(-1px);
        }

    .btn-back-custom {
        background-color: #d7e6eb;
        color: #084c61;
        border: none;
        border-radius: 14px;
        padding: 11px 20px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s ease;
    }

        .btn-back-custom:hover {
            background-color: #c4dbe2;
            color: #063b4b;
        }

    .validation-summary-errors ul {
        margin-bottom: 16px;
        padding-left: 18px;
    }

    .text-danger {
        font-size: 13px;
    }
</style>

<div class="form-page-header">
    <h2>Editar categoría</h2>
    <p>Actualice la información de la categoría seleccionada.</p>
</div>

<div class="form-card">
    <div class="section-title">
        Información de la categoría
    </div>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Nombre" class="form-label custom-label">Nombre de la categoría</label>
            <input asp-for="Nombre" class="form-control custom-input" placeholder="Ejemplo: Bebidas, Postres, Acompañamientos..." />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="status-box">
            <div class="status-box-title">Estado de la categoría</div>

            <div class="form-check form-switch">
                <input class="form-check-input" asp-for="Activo" />
                <label class="form-check-label" asp-for="Activo">
                    Categoría activa
                </label>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save-custom">
                <i class="bi bi-check-circle"></i>
                Guardar cambios
            </button>

            <a asp-action="Index" class="btn-back-custom">
                <i class="bi bi-arrow-left"></i>
                Volver al listado
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}