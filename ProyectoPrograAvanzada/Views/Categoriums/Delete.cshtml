@model ProyectoPrograAvanzada.Models.Categorium

@{
    ViewData["Title"] = "Eliminar categoría";
}

<style>
    .delete-page-header {
        margin-bottom: 24px;
    }

        .delete-page-header h2 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            color: #084c61;
        }

        .delete-page-header p {
            margin: 6px 0 0 0;
            color: #6c757d;
            font-size: 14px;
        }

    .delete-card {
        background-color: #f8fbfc;
        border-radius: 20px;
        padding: 28px;
        box-shadow: inset 0 0 0 1px rgba(8, 76, 97, 0.06);
        max-width: 760px;
    }

    .warning-box {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        background-color: #fff4e5;
        border: 1px solid #ffd9a8;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 24px;
    }

    .warning-icon {
        width: 42px;
        height: 42px;
        min-width: 42px;
        border-radius: 50%;
        background-color: #ffe3bf;
        color: #b45309;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .warning-content h5 {
        margin: 0 0 6px 0;
        color: #9a3412;
        font-weight: 700;
    }

    .warning-content p {
        margin: 0;
        color: #7c2d12;
        font-size: 14px;
    }

    .details-box {
        background-color: #ffffff;
        border: 1px solid #dbe7eb;
        border-radius: 18px;
        padding: 22px;
    }

    .details-title {
        font-size: 16px;
        font-weight: 700;
        color: #084c61;
        margin-bottom: 18px;
    }

    .detail-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 14px 0;
        border-bottom: 1px solid #edf2f5;
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-label {
        color: #64748b;
        font-weight: 600;
        font-size: 14px;
    }

    .detail-value {
        color: #1e293b;
        font-weight: 600;
        font-size: 15px;
        text-align: right;
    }

    .status-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .status-active {
        background-color: #d1f0dd;
        color: #18794e;
    }

    .status-inactive {
        background-color: #f8d7da;
        color: #842029;
    }

    .delete-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 26px;
    }

    .btn-delete-custom {
        background-color: #dc2626;
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 11px 22px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s ease;
    }

        .btn-delete-custom:hover {
            background-color: #b91c1c;
            color: #fff;
            transform: translateY(-1px);
        }

    .btn-cancel-custom {
        background-color: #d7e6eb;
        color: #084c61;
        border: none;
        border-radius: 14px;
        padding: 11px 20px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.25s ease;
    }

        .btn-cancel-custom:hover {
            background-color: #c4dbe2;
            color: #063b4b;
        }
</style>

<div class="delete-page-header">
    <h2>Eliminar categoría</h2>
    <p>Confirme la eliminación de la categoría seleccionada.</p>
</div>

<div class="delete-card">
    <div class="warning-box">
        <div class="warning-icon">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <div class="warning-content">
            <h5>¿Está seguro de eliminar esta categoría?</h5>
            <p>
                Esta acción puede afectar la organización de productos asociados. Verifique la información antes de continuar.
            </p>
        </div>
    </div>

    <div class="details-box">
        <div class="details-title">Información de la categoría</div>

        <div class="detail-row">
            <div class="detail-label">Nombre</div>
            <div class="detail-value">@Model.Nombre</div>
        </div>

        <div class="detail-row">
            <div class="detail-label">Estado</div>
            <div class="detail-value">
                @if (Model.Activo)
                {
                    <span class="status-badge status-active">Activa</span>
                }
                else
                {
                    <span class="status-badge status-inactive">Inactiva</span>
                }
            </div>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-2">
        <input type="hidden" asp-for="Id" />

        <div class="delete-actions">
            <button type="submit" class="btn-delete-custom">
                <i class="bi bi-trash"></i>
                Eliminar categoría
            </button>

            <a asp-action="Index" class="btn-cancel-custom">
                <i class="bi bi-arrow-left"></i>
                Cancelar
            </a>
        </div>
    </form>
</div>